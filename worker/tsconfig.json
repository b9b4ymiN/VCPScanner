{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "types": ["@cloudflare/workers-types"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "paths": {
      "@server/*": ["../server/*"]
    }
  },
  "include": ["src/**/*.ts", "../server/strategies/**/*.ts", "../server/indicators/**/*.ts", "../server/core/types.ts"],
  "exclude": ["node_modules"]
}
